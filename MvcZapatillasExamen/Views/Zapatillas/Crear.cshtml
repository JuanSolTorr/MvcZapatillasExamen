@model MvcZapatillasExamen.Models.Zapatilla

@{
    ViewData["Title"] = "Ańadir Zapatilla";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-4">
                    <h2 class="mb-0"><i class="bi bi-plus-square"></i> Ańadir Nueva Zapatilla</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Crear" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre</label>
                            <input asp-for="Nombre" class="form-control form-control-lg" placeholder="Ej: Nike Air Max" required />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Describe la zapatilla..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label for="imagenZapatilla" class="form-label fw-bold">Imagen de la Zapatilla</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-file-image"></i></span>
                                <input type="file" name="imagenZapatilla" id="imagenZapatilla" class="form-control" accept="image/*" required />
                            </div>
                            <small class="text-muted">Selecciona una imagen en formato JPG, PNG o WebP.</small>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end border-top pt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg me-md-2">
                                <i class="bi bi-arrow-left"></i> Volver al catálogo
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-save"></i> Guardar Zapatilla
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
