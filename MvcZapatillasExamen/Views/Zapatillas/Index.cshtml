@model IEnumerable<MvcZapatillasExamen.Models.Zapatilla>
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Nuestro Cat·logo";
    // Leemos la URL base de tu appsettings.json
    string bucketUrl = Configuration.GetValue<string>("AWS:BucketUrl");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold"><i class="bi bi-collection"></i> Cat·logo de Zapatillas</h1>
        <a asp-action="Crear" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle"></i> Nueva Zapatilla
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        @if (!string.IsNullOrEmpty(item.ImagenUrl))
                        {
                            // CONCATENAMOS: Si el registro ya trae "https", lo dejamos.
                            // Si solo trae el nombre ("dunk_low.jpg"), le pegamos la URL de tu appsettings delante.
                            string rutaFinalImagen = item.ImagenUrl.StartsWith("http")
                            ? item.ImagenUrl
                            : $"{bucketUrl}{item.ImagenUrl}";

                            <img src="@rutaFinalImagen" class="card-img-top" alt="@item.Nombre" style="height: 250px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-light text-muted" style="height: 250px;">
                                <i class="bi bi-image" style="font-size: 4rem;"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@item.Nombre</h5>
                            <p class="card-text text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">@item.Descripcion</p>
                        </div>
                        <div class="card-footer bg-white border-top-0 pb-3">
                            <a href="#" class="btn btn-outline-dark w-100">Ver Detalles</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-3 fs-5">No hay zapatillas en el cat·logo ahora mismo.</p>
            </div>
        }
    </div>
</div>